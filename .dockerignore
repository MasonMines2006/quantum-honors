# Files and folders that should NOT be copied into the Docker image.
# Keeps the image lean and avoids baking in stale output or local config.

# Generated output — gets recreated when the container runs
results.png

# Python bytecode — gets regenerated inside the container
__pycache__/
*.pyc
*.pyo

# Git history — not needed inside the image
.git/
.gitignore

# macOS metadata
.DS_Store
